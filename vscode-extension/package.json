{
  "name": "apex-orchestrator",
  "displayName": "Apex Orchestrator",
  "description": "Run Apex Orchestrator plans directly from VS Code",
  "version": "0.1.0",
  "publisher": "apex",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Machine Learning",
    "Testing",
    "Other"
  ],
  "activationEvents": [
    "onCommand:apex.projectScan",
    "onCommand:apex.semanticPatch",
    "onCommand:apex.runTests",
    "onCommand:apex.openPresenceLog"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "apex.projectScan",
        "title": "Apex: Project Scan"
      },
      {
        "command": "apex.semanticPatch",
        "title": "Apex: Generate Semantic Patch"
      },
      {
        "command": "apex.runTests",
        "title": "Apex: Run Tests"
      },
      {
        "command": "apex.openPresenceLog",
        "title": "Apex: Open Presence Log"
      }
    ],
    "configuration": {
      "title": "Apex Orchestrator",
      "properties": {
        "apex.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Path to the Python executable"
        },
        "apex.projectRoot": {
          "type": "string",
          "default": "",
          "description": "Project root directory (defaults to workspace root)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "18.x",
    "typescript": "^5.0.0"
  }
}
